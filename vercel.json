{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/platforms/sync",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/check-competitors",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 2 * * *"
    }
  ]
}
