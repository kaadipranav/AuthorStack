# AuthorStack - Production Environment Variables
# Copy this file to .env.production.local and fill in actual values
# NEVER commit .env.production.local to git
# Use Vercel/hosting provider's environment variable UI for actual secrets

# ============================================================================
# SUPABASE - Database & Authentication
# ============================================================================
# Get from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CRITICAL: Service role key - NEVER expose to client
# Only use in server-side code (API routes, middleware)
# Get from: Supabase Dashboard > Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# NEXTAUTH - Session & OAuth
# ============================================================================
# Generate with: openssl rand -base64 32
# CRITICAL: Keep this secret and unique per environment
NEXTAUTH_SECRET=your-secure-random-secret-min-32-chars

# Must match your production domain
NEXTAUTH_URL=https://authorstack.com

# ============================================================================
# GOOGLE OAUTH - Authentication Provider
# ============================================================================
# Get from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# WHOP - Payment Processing & Subscriptions
# ============================================================================
# Get from: Whop Dashboard > Settings > API Keys
WHOP_API_KEY=your-whop-api-key
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret

# ============================================================================
# RESEND - Email Service
# ============================================================================
# Get from: Resend Dashboard > API Keys
RESEND_API_KEY=re_your-resend-api-key

# ============================================================================
# UPSTASH - Redis Cache & QStash Jobs
# ============================================================================
# Get from: Upstash Console > Redis > Connection
UPSTASH_REDIS_URL=redis://default:password@host:port
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# Get from: Upstash Console > QStash > Tokens
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-signing-key

# ============================================================================
# CRON JOBS - Security
# ============================================================================
# Generate with: openssl rand -base64 32
# Used to verify cron job requests from Vercel/Upstash
CRON_SECRET=your-cron-secret-min-32-chars

# ============================================================================
# SENTRY - Error Monitoring
# ============================================================================
# Get from: Sentry > Settings > Projects > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ============================================================================
# POSTHOG - Analytics
# ============================================================================
# Get from: PostHog > Project Settings > API Key
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================================
# APPLICATION - General Settings
# ============================================================================
# Environment identifier
NODE_ENV=production

# Application URL
APP_URL=https://authorstack.com

# ============================================================================
# OPTIONAL - Development/Testing
# ============================================================================
# Test user UUID for development (leave empty in production)
# TEST_USER_ID=

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
# 1. NEVER commit .env.production.local to git
# 2. Use Vercel's Environment Variables UI for all secrets
# 3. Set different secrets for staging vs production
# 4. Rotate secrets regularly (especially API keys)
# 5. Use strong, randomly generated secrets (min 32 characters)
# 6. Enable Vercel's "Sensitive" flag for sensitive variables
# 7. Test environment variables before deploying
# 8. Monitor Sentry for errors in production
# 9. Check Upstash logs for job failures
# 10. Verify RLS policies are enabled in Supabase
