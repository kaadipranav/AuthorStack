# ============================================
# AuthorStack Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# .env.local is gitignored and used for local development

# ============================================
# SUPABASE (Database & Auth)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# WHOP (Payments & Subscriptions)
# ============================================
NEXT_PUBLIC_WHOP_API_KEY=your-whop-api-key-here
WHOP_SECRET_KEY=your-whop-secret-key-here
NEXT_PUBLIC_WHOP_WEBHOOK_SECRET=your-whop-webhook-secret-here

# ============================================
# RESEND (Email Service)
# ============================================
RESEND_API_KEY=your-resend-api-key-here

# ============================================
# UPSTASH REDIS (Caching & Rate Limiting)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-region-your-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ============================================
# UPSTASH QSTASH (Background Jobs & Cron)
# ============================================
QSTASH_TOKEN=your-qstash-token-here
QSTASH_CURRENT_SIGNING_KEY=your-qstash-signing-key-here
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key-here

# ============================================
# SENTRY (Error Tracking & Monitoring)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# ============================================
# ANALYTICS (PostHog or Plausible)
# ============================================
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# OR for Plausible:
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# ============================================
# EXTERNAL PLATFORM APIs
# ============================================
# Gumroad API
GUMROAD_API_KEY=your-gumroad-api-key-here

# Amazon KDP (Web Scraping)
# Note: Use environment variables for credentials if needed
# AMAZON_KDP_EMAIL=your-email@example.com
# AMAZON_KDP_PASSWORD=your-password-here

# ============================================
# APPLICATION SETTINGS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AuthorStack

# API Routes Base URL (for internal API calls)
API_BASE_URL=http://localhost:3000/api

# ============================================
# VERCEL DEPLOYMENT
# ============================================
# These are auto-set by Vercel, but you can override:
# VERCEL_ENV=development
# VERCEL_URL=your-deployment-url.vercel.app

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Set to true to enable verbose logging
DEBUG=false
NODE_ENV=development

# ============================================
# WEBHOOK SIGNING SECRETS
# ============================================
# Used to verify webhook authenticity
WHOP_WEBHOOK_SIGNING_SECRET=your-whop-webhook-signing-secret-here
RESEND_WEBHOOK_SIGNING_SECRET=your-resend-webhook-signing-secret-here
